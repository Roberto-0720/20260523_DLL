<Window x:Class="SteelCadPlugin.UI.SectionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steel Section Picker — SteelCAD"
        Width="680" Height="540"
        MinWidth="480" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E"
        Foreground="#E0E0E0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="AccentBrush"    Color="#4FC3F7"/>
        <SolidColorBrush x:Key="PanelBrush"     Color="#16213E"/>
        <SolidColorBrush x:Key="RowOddBrush"    Color="#0F3460"/>
        <SolidColorBrush x:Key="RowEvenBrush"   Color="#16213E"/>
        <SolidColorBrush x:Key="SelectedBrush"  Color="#4FC3F7"/>
        <SolidColorBrush x:Key="TextBrush"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SubTextBrush"   Color="#90A4AE"/>

        <!-- TextBox style -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"   Value="#0F3460"/>
            <Setter Property="Foreground"   Value="#E0E0E0"/>
            <Setter Property="BorderBrush"  Value="#4FC3F7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="CaretBrush"   Value="#4FC3F7"/>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="TypeCombo" TargetType="ComboBox">
            <Setter Property="Background"   Value="#0F3460"/>
            <Setter Property="Foreground"   Value="#E0E0E0"/>
            <Setter Property="BorderBrush"  Value="#4FC3F7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,4"/>
        </Style>

        <!-- Button style -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background"   Value="#4FC3F7"/>
            <Setter Property="Foreground"   Value="#0D0D1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#81D4FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0288D1"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Background"   Value="#263238"/>
            <Setter Property="Foreground"   Value="#90A4AE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"  Value="#455A64"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#37474F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid styles -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#E0E0E0"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#263238"/>
            <Setter Property="RowBackground"    Value="#16213E"/>
            <Setter Property="AlternatingRowBackground" Value="#0F3460"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode"    Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows"   Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly"       Value="True"/>
            <Setter Property="FontSize"         Value="12"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#0D47A1"/>
            <Setter Property="Foreground"   Value="#E3F2FD"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush"  Value="#1565C0"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D3B8E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Filter bar -->
            <RowDefinition Height="*"/>     <!-- Grid -->
            <RowDefinition Height="Auto"/>  <!-- Info panel -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="#0D47A1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="⬛ Steel Section Database"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#E3F2FD"/>
                    <TextBlock x:Name="TotalCountText"
                               Text="Loading..." FontSize="11"
                               Foreground="#90CAF9" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Filter bar ── -->
        <Border Grid.Row="1" Background="#0F3460" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Type:" VerticalAlignment="Center"
                           Margin="0,0,8,0" Foreground="#90A4AE"/>
                <ComboBox Grid.Column="1" x:Name="TypeComboBox" Style="{StaticResource TypeCombo}"
                          SelectionChanged="TypeComboBox_SelectionChanged"/>
                <TextBlock Grid.Column="3" Text="Search:" VerticalAlignment="Center"
                           Margin="0,0,8,0" Foreground="#90A4AE"/>
                <TextBox Grid.Column="4" x:Name="SearchBox" Style="{StaticResource SearchBox}"
                         TextChanged="SearchBox_TextChanged"
                         ToolTip="Type section name to filter..."/>
            </Grid>
        </Border>

        <!-- ── Data grid ── -->
        <DataGrid Grid.Row="2" x:Name="SectionGrid" Margin="0"
                  SelectionChanged="SectionGrid_SelectionChanged"
                  MouseDoubleClick="SectionGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Section Name" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="d (mm)"  Binding="{Binding d,  StringFormat=F1}" Width="70"/>
                <DataGridTextColumn Header="bf (mm)" Binding="{Binding bf, StringFormat=F1}" Width="70"/>
                <DataGridTextColumn Header="tw (mm)" Binding="{Binding tw, StringFormat=F1}" Width="70"/>
                <DataGridTextColumn Header="tf (mm)" Binding="{Binding tf, StringFormat=F1}" Width="70"/>
                <DataGridTextColumn Header="A (mm²)" Binding="{Binding Area, StringFormat=F0}" Width="80"/>
                <DataGridTextColumn Header="W (kg/m)" Binding="{Binding Weight, StringFormat=F2}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Info panel ── -->
        <Border Grid.Row="3" Background="#0D47A1" Padding="12,8"
                x:Name="InfoPanel" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Selected: " Foreground="#90CAF9" FontSize="12"/>
                <TextBlock x:Name="SelectedInfoText"
                           Foreground="White" FontSize="12" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- ── Buttons ── -->
        <Border Grid.Row="4" Background="#16213E" Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel"
                        Style="{StaticResource CancelBtn}"
                        Click="CancelButton_Click" Margin="0,0,8,0"/>
                <Button x:Name="OkButton" Content="✔ Use This Section"
                        Style="{StaticResource AccentBtn}"
                        IsDefault="True"
                        Click="OkButton_Click" IsEnabled="False"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
