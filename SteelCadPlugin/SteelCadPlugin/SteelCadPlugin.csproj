<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net47</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>SteelCadPlugin</AssemblyName>
    <RootNamespace>SteelCadPlugin</RootNamespace>
    <PlatformTarget>x64</PlatformTarget>
    <Platforms>x64</Platforms>
    <LangVersion>7.3</LangVersion>
    <Nullable>disable</Nullable>
    <OutputType>Library</OutputType>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

  <!-- AutoCAD NuGet packages - ExcludeAssets=runtime so DLLs are NOT bundled in output -->
  <ItemGroup>
    <PackageReference Include="AutoCAD.NET" Version="23.1.0" ExcludeAssets="runtime" />
    <PackageReference Include="AutoCAD.NET.Core" Version="23.1.0" ExcludeAssets="runtime" />
  </ItemGroup>

  <!-- NuGet: ClosedXML for reading Excel -->
  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.95.0" />
  </ItemGroup>

</Project>
